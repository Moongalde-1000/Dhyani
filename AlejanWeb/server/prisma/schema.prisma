// schema.prisma
datasource db {
  provider     = "mongodb"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  DEFAULT
  ADMIN
  CLIENT
}

enum Country {
  USA
  IND
}

model Users {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  fullName      String
  displayName   String
  username      String?    @unique
  email         String     @unique
  phone         String?
  password      String
  profileImage  String?
  authToken     String?
  lastLoginAt DateTime?
  role          UserRole   @default(DEFAULT)
  is_suspended   Boolean     @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}


model Logs {
  id   String    @id @default(auto()) @map("_id") @db.ObjectId
  data Json
}

model StaticPage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  staticType   String
  title String   @default("")
  staticImage String   @default("")
  description String   @default("")
  phone       String   @default("")
  email       String   @default("")
  location    String   @default("")
  goalText     String   @default("")
  missionDescription     String   @default("")
  visionDescription     String   @default("")
  valuesDescription     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId        String   @db.ObjectId
  eventTitle      String
  location        String
  latitude        Float?
  longitude       Float?
  eventDate       DateTime
  eventStartTime  String
  eventEndTime    String
  description     String
  eventImages     String[]
  eventVideos     String[]
  qrCodeLink      String?
  publicEventURL  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Team{
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  designation        String
  linkedInID     String
  twitterID     String
  teamImage     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContactUs{
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email        String
  phone     String
  subject     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Faq{
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  description        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteSetting{
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  signUpTitle   String
  loginTitle   String
  forgotPasswordTitle   String
  aboutpageTitle   String
  contactusTitle   String
  faqTitle   String
  eventListTitle   String
  myEventDetailTitle   String
  publicEventDetailTitle   String
  footerTitle   String
  footerDescription   String
  linkedInID     String
  twitterID     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Guest {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId        String   @db.ObjectId
  name   String
  email   String
  phone   String
  noOfPerson   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChangeLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  role        UserRole
  description String
  module      String
  oldValues   Json
  newValues   Json
  oldValue    String   @default("")
  newValue    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
